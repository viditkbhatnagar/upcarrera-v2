# Copy to apps/web/.env (dev) or set at build time. VITE_* values are inlined
# into the client bundle by Vite at build — they are NOT runtime config.
#
# Base URL the browser uses to reach the NestJS API.
#   - dev (default if unset): http://localhost:3000/api
#   - production: /api  (same-origin; nginx proxies /api on each domain to the API)
VITE_API_URL=http://localhost:3000/api
