# Copy to apps/api/.env and fill in. Never commit the real .env.
# ---- Core ----
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/upcarrera"
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"
PORT=3000

# ---- Integrations (all OPTIONAL & env-gated) ----
# The app runs fine without these — each provider degrades gracefully
# (health probe reports false; calls throw a clear 'not configured' error).
# Fill them in to activate the real integrations.

# Zoom Server-to-Server OAuth (meeting provisioning)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
# Zoom Meeting SDK (in-app / live-class signatures)
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# Brevo (Sendinblue) transactional email
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@upcarrera.com
BREVO_SENDER_NAME=upCarrera

# 2factor.in SMS / OTP delivery
OTP_API_KEY=

# Razorpay (payment gateway) — also stored in the settings table for the legacy app
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
