# Copy to apps/api/.env and fill in. Never commit the real .env.
# ---- Core ----
# Local dev: mysql://USER:PASSWORD@HOST:3306/upcarrera
# DO Managed MySQL (production) requires TLS — append the SSL params and ship the
# DO CA cert to the droplet, e.g.:
#   mysql://USER:PASSWORD@HOST:25060/upcarrera?sslaccept=strict&sslcert=/opt/upcarrera/certs/ca-certificate.crt
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/upcarrera"
# REQUIRED in production — the API refuses to boot without it (no insecure default).
# Generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"
PORT=3000
# Bind host: 0.0.0.0 (default) for local/dev; set 127.0.0.1 in production so the
# API is only reachable through nginx (PM2 sets this — see ecosystem.config.js).
HOST=0.0.0.0
# CORS: comma-separated allow-list of web origins for production. When unset the
# API stays permissive (dev default). Not needed if web calls the API same-origin
# via a relative /api base (the recommended two-domain setup).
# CORS_ORIGINS=https://admin.upcarrera.com,https://admissions.upcarrera.com

# ---- Integrations (all OPTIONAL & env-gated) ----
# The app runs fine without these — each provider degrades gracefully
# (health probe reports false; calls throw a clear 'not configured' error).
# Fill them in to activate the real integrations.

# Zoom Server-to-Server OAuth (meeting provisioning)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
# Zoom Meeting SDK (in-app / live-class signatures)
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# Brevo (Sendinblue) transactional email
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@upcarrera.com
BREVO_SENDER_NAME=upCarrera

# 2factor.in SMS / OTP delivery
OTP_API_KEY=

# Razorpay (payment gateway) — also stored in the settings table for the legacy app
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
